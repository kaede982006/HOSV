# Official BytePlus ModelArk configuration.
# Copy to .env locally if your shell tooling loads it. Do not commit real credentials.

BYTEPLUS_ARK_API_KEY="ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-xxxxx"
# ARK_API_KEY=

BYTEPLUS_ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
BYTEPLUS_ARK_MODEL=dreamina-seedance-2-0-260128
BYTEPLUS_ARK_FAST_MODEL=dreamina-seedance-2-0-fast-260128
BYTEPLUS_ARK_REGION=ap-southeast
BYTEPLUS_ARK_TIMEOUT_MS=120000
BYTEPLUS_ARK_POLL_INITIAL_MS=3000
BYTEPLUS_ARK_POLL_MAX_MS=15000
BYTEPLUS_ARK_POLL_TIMEOUT_MS=900000
BYTEPLUS_ARK_DEBUG=false

# Optional: point the C++ app at a custom bridge binary.
# BYTEPLUS_ARK_BRIDGE_PATH=./arkbridge
